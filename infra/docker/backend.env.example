#####################################
# Shuestand environment configuration
#####################################

# -----------------------------------
# The network (bitcoin, testnet, signet)
BITCOIN_NETWORK=bitcoin

# ------------------
# The Operator Token
# ------------------
# Access token for the operator panel.
WALLET_API_TOKEN=replace-with-strong-token (e.g. "openssl rand -hex 32")

# -----------------------------------
# Postgres DB Link
DATABASE_URL=postgres://shuestand:change-me@postgres:5432/shuestand

# --------------------------
# Wallet Seed or Descriptors
# --------------------------
# If both Seed and Descriptors are set then
# the descriptors are optional but take 
# precendence if present
BITCOIN_WALLET_SEED="please insert your own twelve secret words here and create the wallet"
BITCOIN_DESCRIPTOR=replace-with-xprv-descriptor
BITCOIN_SPEND_DESCRIPTOR=replace-with-spend-descriptor
BITCOIN_CHANGE_DESCRIPTOR=replace-with-change-descriptor
ADDRESS_POOL_TARGET=20
DEPOSIT_TARGET_CONFIRMATIONS=2

#----------------------------------------
# Liquidity (Float) Management and Guards
#----------------------------------------
# The float params specify the target and the
# lower and upper limit of the pool. If the band
# is exceeded a warning is shown in the operator panel
FLOAT_TARGET_SATS=500000
FLOAT_MIN_RATIO=0.5
FLOAT_MAX_RATIO=2.0
FLOAT_GUARD_INTERVAL_SECS=30

# --------------
# Chain Explorer
# --------------
# If both espora and electrum are present Electrum takes precedence
BITCOIN_ELECTRUM_URL=ssl://electrum.mountainlake.io:50002
BITCOIN_ELECTRUM_VALIDATE_DOMAIN=true
#BITCOIN_ESPLORA_BASE_URL=https://blockstream.info/api

# --------------
# Canonical Mint
# --------------
# The mint only keeps token of this mint.
# Foreign tokens, offered in a withdrawal
# request, are first converted.
# ---------------------------------------
CASHU_MINT_URL=https://m7.mountainlake.io
CASHU_WALLET_DIR=/data/cashu

WITHDRAWAL_WORKER_ENABLED=true
WITHDRAWAL_WORKER_INTERVAL_SECS=15
WITHDRAWAL_WORKER_MAX_ATTEMPTS=3

# ------------------
# Transaction Limits
# ------------------
# No transaction can use more than this part of the available float
SINGLE_REQUEST_CAP_RATIO=0.5
# Smallest transaction amount
WITHDRAWAL_MIN_SATS=50000

