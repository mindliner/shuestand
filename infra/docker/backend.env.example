#####################################
# Shuestand backend environment file
#####################################

# ==================================================
# Core service
# ==================================================
DATABASE_URL=postgres://shuestand:change-me@postgres:5432/shuestand
#SHUESTAND_BACKEND_PORT=8080
#RUST_LOG=backend=debug

# ==================================================
# Network + wallet identity
# ==================================================
BITCOIN_NETWORK=bitcoin

# Descriptors are required.
# Seed -> descriptor helper:
#   cd shuestand/backend
#   cargo run --bin descriptor_gen -- --network bitcoin --seed-file /secure/seed.txt --template --output-env /secure/bitcoin-descriptors.env
# Then copy BITCOIN_*DESCRIPTOR values from that output into this file.
BITCOIN_DESCRIPTOR=replace-with-xprv-descriptor
BITCOIN_SPEND_DESCRIPTOR=replace-with-spend-descriptor
BITCOIN_CHANGE_DESCRIPTOR=replace-with-change-descriptor

# ==================================================
# Chain backends (Electrum preferred over Esplora)
# ==================================================
BITCOIN_ELECTRUM_URL=ssl://electrum.mountainlake.io:50002
BITCOIN_ELECTRUM_VALIDATE_DOMAIN=true
#BITCOIN_ELECTRUM_SOCKS5=socks5://127.0.0.1:9050
#BITCOIN_ESPLORA_BASE_URL=https://blockstream.info/api

# ==================================================
# Address pool + confirmation policy
# ==================================================
ADDRESS_POOL_TARGET=20
DEPOSIT_TARGET_CONFIRMATIONS=2
#WITHDRAWAL_TARGET_CONFIRMATIONS=1
#CONFIRMATION_POLL_INTERVAL_SECS=30

# ==================================================
# Worker controls
# ==================================================
WITHDRAWAL_WORKER_ENABLED=true
WITHDRAWAL_WORKER_INTERVAL_SECS=15
WITHDRAWAL_WORKER_MAX_ATTEMPTS=3
#WITHDRAWAL_PAYOUT_FEE_RATE_VB=2.0

#DEPOSIT_WORKER_ENABLED=true
#DEPOSIT_WORKER_INTERVAL_SECS=10
#DEPOSIT_WORKER_MAX_ATTEMPTS=5

# ==================================================
# Cashu mint + local wallet
# ==================================================
CASHU_MINT_URL=https://m7.mountainlake.io
CASHU_WALLET_DIR=/data/cashu

# Public HTTPS base URL used for NUT-18 callback targets
#PUBLIC_BASE_URL=https://shuestand.mountainlake.io

# ==================================================
# Operator/API security
# ==================================================
WALLET_API_TOKEN=replace-with-strong-token
#TRUST_PROXY_HEADERS=true
#CORS_ALLOWED_ORIGINS=https://shuestand.mountainlake.io

# ==================================================
# Float management
# ==================================================
FLOAT_TARGET_SATS=500000
FLOAT_MIN_RATIO=0.5
FLOAT_MAX_RATIO=2.0
FLOAT_GUARD_INTERVAL_SECS=30
#FLOAT_DRIFT_ALERT_RATIO=0.1
#FLOAT_DRIFT_ALERT_SATS=50000

# ==================================================
# Transaction sizing + anti-abuse controls
# ==================================================
# Fraction of float allowed per single request
SINGLE_REQUEST_CAP_RATIO=0.1

# Auto-fail pending/partial deposits after this many seconds
PENDING_DEPOSIT_TTL_SECS=600
# Max concurrent pending+confirming deposits per session
MAX_PENDING_DEPOSITS_PER_SESSION=2

# Minimum transaction sizes
DEPOSIT_MIN_SATS=25000
WITHDRAWAL_MIN_SATS=25000
# Extra sats requested on payment requests to absorb swap/redeem slippage
WITHDRAWAL_FEE_BUFFER_SATS=50

# ==================================================
# Fee estimator (optional bitcoind RPC)
# ==================================================
#BITCOIND_RPC_URL=http://bitcoind:8332
#BITCOIND_RPC_USER=replace-with-rpc-user
#BITCOIND_RPC_PASSWORD=replace-with-rpc-password
#FEE_ESTIMATOR_REFRESH_SECS=60
#FEE_ESTIMATOR_FAST_BLOCKS=1
#FEE_ESTIMATOR_ECONOMY_BLOCKS=3
#FEE_ESTIMATOR_MIN_SAT_PER_VB=1
#FEE_ESTIMATOR_MAX_SAT_PER_VB=500

# ==================================================
# Optional webhooks
# ==================================================
#FLOAT_ALERT_WEBHOOK_URL=https://n8n.example.com/webhook/float-alerts
#TRANSACTION_WEBHOOK_URL=https://n8n.example.com/webhook/transactions
#SECURITY_ALERT_WEBHOOK_URL=https://n8n.example.com/webhook/security-alerts
