#####################################
# Shuestand environment configuration
#####################################

# -----------------------------------
# The network (bitcoin, testnet, signet)
BITCOIN_NETWORK=bitcoin

# ------------------
# The Operator Token
# ------------------
# Access token for the operator panel.
WALLET_API_TOKEN=replace-with-strong-token (e.g. "openssl rand -hex 32")

# -----------------------------------
# Postgres DB Link
DATABASE_URL=postgres://shuestand:change-me@postgres:5432/shuestand

# --------------------------
# Wallet Seed or Descriptors
# --------------------------
# If both Seed and Descriptors are set then
# the descriptors are optional but take 
# precendence if present
BITCOIN_WALLET_SEED="please insert your own twelve secret words here and create the wallet"
BITCOIN_DESCRIPTOR=replace-with-xprv-descriptor
BITCOIN_SPEND_DESCRIPTOR=replace-with-spend-descriptor
BITCOIN_CHANGE_DESCRIPTOR=replace-with-change-descriptor
ADDRESS_POOL_TARGET=20
DEPOSIT_TARGET_CONFIRMATIONS=2

#----------------------------------------
# Liquidity (Float) Management and Guards
#----------------------------------------
# The float params specify the target and the
# lower and upper limit of the pool. If the band
# is exceeded a warning is shown in the operator panel
FLOAT_TARGET_SATS=500000
FLOAT_MIN_RATIO=0.5
FLOAT_MAX_RATIO=2.0
FLOAT_GUARD_INTERVAL_SECS=30
# The fraction of FLOAT_TARGET_SATS the total float must change between checks
# before emitting a drift alert (default 0.10 = 10%)
#FLOAT_DRIFT_ALERT_RATIO=0.1
# Optional webhook for float alerts (low/high bands + drift delta events)
#FLOAT_ALERT_WEBHOOK_URL=https://n8n.example.com/webhook/float-alerts
# Optional webhook that receives the running transaction counter whenever
# a deposit is fulfilled or a withdrawal is settled.
#TRANSACTION_WEBHOOK_URL=https://n8n.example.com/webhook/transactions

# --------------
# Chain Explorer
# --------------
# If both espora and electrum are present Electrum takes precedence
BITCOIN_ELECTRUM_URL=ssl://electrum.mountainlake.io:50002
BITCOIN_ELECTRUM_VALIDATE_DOMAIN=true
#BITCOIN_ESPLORA_BASE_URL=https://blockstream.info/api

# -----------------
# Fee Estimation
# -----------------
# Use your own bitcoind RPC for dynamic fee rates.
#BITCOIND_RPC_URL=http://bitcoind:8332
#BITCOIND_RPC_USER=replace-with-rpc-user
#BITCOIND_RPC_PASSWORD=replace-with-rpc-password
# Optional tuning (defaults: 60s refresh, fast=1 block, economy=3 blocks, clamp 1–500 sat/vB)
#FEE_ESTIMATOR_REFRESH_SECS=60
#FEE_ESTIMATOR_FAST_BLOCKS=1
#FEE_ESTIMATOR_ECONOMY_BLOCKS=3
#FEE_ESTIMATOR_MIN_SAT_PER_VB=1
#FEE_ESTIMATOR_MAX_SAT_PER_VB=500

# --------------
# Canonical Mint
# --------------
# The mint only keeps token of this mint.
# Foreign tokens, offered in a withdrawal
# request, are first converted.
# ---------------------------------------
CASHU_MINT_URL=https://m7.mountainlake.io
CASHU_WALLET_DIR=/data/cashu
# Public HTTPS base URL used for NUT-18 callback targets.
# Set this so payment requests stay reachable outside LAN/VPN.
#PUBLIC_BASE_URL=https://shuestand.mountainlake.io

WITHDRAWAL_WORKER_ENABLED=true
WITHDRAWAL_WORKER_INTERVAL_SECS=15
WITHDRAWAL_WORKER_MAX_ATTEMPTS=3

# ------------------
# Transaction Limits
# ------------------
# No transaction can use more than this part of the available float
# If you expect up to N people to go simultaneously in one direction 
# (C->B or B->C), only, then the value should be (1/N + buffer)
SINGLE_REQUEST_CAP_RATIO=0.1
# Minimum Bitcoin -> Cashu deposit
DEPOSIT_MIN_SATS=25000
# Smallest transaction amount, avoid dust UTXOs
WITHDRAWAL_MIN_SATS=25000
# Extra sats requested on payment requests to absorb swap/redeem fee slippage
WITHDRAWAL_FEE_BUFFER_SATS=500
